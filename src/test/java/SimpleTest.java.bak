import com.github.tomakehurst.wiremock.WireMockServer;
import com.github.tomakehurst.wiremock.client.WireMock;

import static com.github.tomakehurst.wiremock.client.WireMock.*;

import io.restassured.RestAssured;
import io.restassured.http.ContentType;
import io.restassured.response.Response;

import org.junit.jupiter.api.AfterAll;
import org.junit.jupiter.api.BeforeAll;
import org.junit.jupiter.api.Test;

import static org.hamcrest.Matchers.*;

public class SimpleTest {

    private static WireMockServer wireMockServer;
    private static final int PORT = 8089;

    @BeforeAll
    public static void setup() {
        // Start WireMock server
        wireMockServer = new WireMockServer(PORT);
        wireMockServer.start();

        // Configure WireMock
        WireMock.configureFor("localhost", PORT);

        // Stub a simple endpoint
        stubFor(get(urlPathEqualTo("/hello"))
                .willReturn(aResponse()
                        .withStatus(200)
                        .withHeader("Content-Type", "application/json")
                        .withBody("{\"message\": \"Hello, World!\"}")));

        // Configure RestAssured
        RestAssured.baseURI = "http://localhost";
        RestAssured.port = PORT;
    }

    @AfterAll
    public static void teardown() {
        if (wireMockServer != null) {
            wireMockServer.stop();
        }
    }

    @Test
    public void testSimpleEndpoint() {
        Response response = RestAssured
                .given()
                .contentType(ContentType.JSON)
                .when()
                .get("/hello")
                .then()
                .statusCode(200)
                .contentType(ContentType.JSON)
                .body("message", equalTo("Hello, World!"))
                .extract()
                .response();

        System.out.println("Test passed! Response: " + response.asString());
    }

    public static void main(String[] args) throws Exception {
        setup();
        try {
            new SimpleTest().testSimpleEndpoint();
            System.out.println("SUCCESS: Simple test passed!");
        } finally {
            teardown();
        }
    }
}
